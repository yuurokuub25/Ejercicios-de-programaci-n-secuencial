Proceso Encontrar_lamedia
    Definir n1, n2, n3, media Como Real
    
    Escribir "Ingrese el primer numero:"
    Leer n1
    
    Escribir "Ingrese el segundo numero:"
    Leer n2
    
    Escribir "Ingrese el tercer numero:"
    Leer n3
    
    media <- (n1 + n2 + n3) / 3
    
    Escribir "La media es: ", media
FinProceso
