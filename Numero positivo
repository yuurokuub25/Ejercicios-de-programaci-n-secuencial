Algoritmo puntaje_final_examen
    Escribir "Programa que calcula puntaje total de un examen con base en la acertividad en cada pregunta"
	Escribir "cantidad de respuestas correctas:"
	Leer correctas
	Escribir "cantidad de respuestas incorrectas:"
	Leer incorrectas
	Escribir "cantidad de respuestas que dejo en blanco:"
	Leer en_blanco
	
	puntos_ganados <- correctas * 5
	puntos_perdidos <- incorrectas * (-1)
	nota_final <- puntos_ganados + puntos_perdidos
	
	Escribir "Su puntaje total en el examen es de: ", nota_final, " puntos"
FinAlgoritmo
